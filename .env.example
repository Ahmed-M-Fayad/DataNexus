# ─────────────────────────────────────────────────────────
#  DataNexus — Environment Variables Template
#  Copy to .env and fill in real values. .env is gitignored.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL (local) ────────────────────────────────────
POSTGRES_USER=datanexus
POSTGRES_PASSWORD=change_me
POSTGRES_DB=datanexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://datanexus:change_me@localhost:5432/datanexus

# ── Airflow (planned — Docker) ────────────────────────────
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://datanexus:change_me@host.docker.internal:5432/airflow

# ── Flask API (planned) ───────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=your_flask_secret_key_here
API_PORT=5000

# ── Streamlit Dashboard ───────────────────────────────────
STREAMLIT_PORT=8501

# ── Alerting — Email (SMTP, planned) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=change_me
ALERT_FROM_EMAIL=your_email@gmail.com
ALERT_TO_EMAIL=team@example.com

# ── Alerting — Slack (planned) ────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Great Expectations ─────────────────────────────────────
GE_ROOT_DIR=great_expectations
